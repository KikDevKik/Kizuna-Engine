# Kizuna Engine - Environment Configuration Example

# -- Environment Mode --
# 'development' = Force Flash for everything (save quota)
# 'production' = Enable Pro models for Architect/Dream (high quality)
ENVIRONMENT=development

# -- API Keys --
# Required for agent reasoning and conversational logic
GEMINI_API_KEY=your_gemini_api_key_here

# -- Code Health / Debugging --
# Set to true to mock Gemini API responses (useful for local UI testing without quota)
MOCK_GEMINI=false

# -- Model Configuration Overrides (Optional) --
# MODEL_LIVE_VOICE=gemini-2.5-flash-native-audio-preview-12-2025
# MODEL_SUBCONSCIOUS='["gemini-2.5-flash", "gemini-3-flash-preview"]'
# MODEL_DREAM='["gemini-3.0-pro-exp", "gemini-3-flash-preview", "gemini-2.5-flash"]'
# MODEL_FORGE=gemini-2.5-flash
# MODEL_FLASH_LITE=gemini-2.5-flash-lite

# -- Web / Networking --
# List of origins allowed by CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# -- Google Cloud / Firebase Configuration --
# ID of the Google Cloud Project
GCP_PROJECT_ID=your_gcp_project_id
# Firebase Admin SDK Credentials (can be path to JSON file or raw JSON content)
FIREBASE_CREDENTIALS=path_to_firebase_adminsdk_json
# Google Cloud Application Credentials (used by Google Cloud SDK, eg. Firestore)
GOOGLE_APPLICATION_CREDENTIALS=path_to_google_app_credentials_json

# -- Spanner Configuration (Legacy/Current fallback) --
SPANNER_INSTANCE_ID=your_spanner_instance_id
SPANNER_DATABASE_ID=your_spanner_database_id

# -- Neo4j Configuration (Graph Database) --
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# -- Redis Configuration (Caching) --
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -- Engine Settings --
# Time in seconds for the grace period before the Sleep Manager triggers consolidation
SLEEP_GRACE_PERIOD=5
